#!/usr/bin/env bash
#MISE description="Check if a bash script stays within the pudding subset"
#USAGE arg "<file>" help="Path to the bash script to check"

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$REPO_DIR/lib/grammar.sh"

file="$usage_file"

if [[ ! -f "$file" ]]; then
  echo "Error: file not found: $file" >&2
  exit 1
fi

echo "Checking: $file"
if check_file "$file"; then
  echo "OK — script is within the pudding subset"
else
  echo ""
  echo "FAIL — script uses constructs outside the pudding subset" >&2
  exit 1
fi
